[DTS.DAP.Reg]
AddReg = DTS.DAP.PresetAddReg

[DTS.DAP.PresetAddReg]
;; Non CAPX 
HKR,EP\0, "{7A8B74C8-FA66-4460-8542-D6119C59E9D4},4", %REG_DWORD%, 0x100  ;; DTS APO on Realtek
HKR,EP\0, "{7A8B74C8-FA66-4460-8542-D6119C59E9D4},10", %REG_DWORD%, 0x009 ;; DTS APO4x AudioProcessing Bypass Count
HKR,EP\0, %DTS_APO_PRODUCT_TYPE%, %REG_DWORD%, 0x001

;; 21H2 CAPX
HKR,FX\0,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,FX\0\%DTSAPO4XSFX_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,FX\0\%DTSAPO4XSFX_PS_CONTEXT%\User,%PKEY_DTS_APO4X_ENTRY%,%REG_DWORD%,0x0

HKR,FX\0\%DTSAPO4XMFX_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,FX\0\%DTSAPO4XMFX_PS_CONTEXT%\User,%PKEY_DTS_APO4X_ENTRY%,%REG_DWORD%,0x0

HKR,FX\0\%DTSAPO4XEFX_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,FX\0\%DTSAPO4XEFX_PS_CONTEXT%\User,%PKEY_DTS_APO4X_ENTRY%,%REG_DWORD%,0x0

HKR,FX\0\%DTSAPO4XGLOBAL_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,FX\0\%DTSAPO4XGLOBAL_PS_CONTEXT%\User,%DTS_EP_APO_BYPASSCNT_CAPX%,REG_DWORD,0x9
;; Product type DAP = 1 
HKR,FX\0\%DTSAPO4XGLOBAL_PS_CONTEXT%\User,%DTS_APO_PRODUCT_TYPE_CAPX%,REG_DWORD,0x1

HKR,FX\0\%DTSAPO4XRESERVE_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,FX\0\%DTSAPO4XRESERVE_PS_CONTEXT%\User,%PKEY_DTS_APO4X_ENTRY%,%REG_DWORD%,0x0

[DTS.DAP.PresetAddRegRTK]
;; Non CAPX
HKR,InterfaceSetting\ApoPreset1\EP\0, "{7A8B74C8-FA66-4460-8542-D6119C59E9D4},4", %REG_DWORD%, 0x100  ;; DTS APO on Realtek
HKR,InterfaceSetting\ApoPreset1\EP\0, "{7A8B74C8-FA66-4460-8542-D6119C59E9D4},10", %REG_DWORD%, 0x009 ;; DTS APO4x AudioProcessing Bypass Count
HKR,InterfaceSetting\ApoPreset1\EP\0, %DTS_APO_PRODUCT_TYPE%, %REG_DWORD%, 0x001

;; 21H2 CAPX
HKR,Settings,EPSubVer1,%REG_DWORD%,1
HKR,InterfaceSetting,RearLineOutTopo,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,PrimaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,SingleLineOutTopo,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,SecondaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,FrontPanelHeadphoneTopo,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,RearLineOutTopoSST,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,RearLineOutTopoSST2,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,RearLineOutTopoSST3,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,RearLineOutTopoDock,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,RearLineOutTopoHap,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,RearLineOutTopoHap2,%REG_MULTI_SZ_APPEND%,"ApoPreset1"
HKR,InterfaceSetting,RearLineOutTopoHap3,%REG_MULTI_SZ_APPEND%,"ApoPreset1"

HKR,InterfaceSetting\ApoPreset1\FX\0,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XSFX_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XSFX_PS_CONTEXT%\User,%PKEY_DTS_APO4X_ENTRY%,%REG_DWORD%,0x0

HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XMFX_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XMFX_PS_CONTEXT%\User,%PKEY_DTS_APO4X_ENTRY%,%REG_DWORD%,0x0

HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XEFX_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XEFX_PS_CONTEXT%\User,%PKEY_DTS_APO4X_ENTRY%,%REG_DWORD%,0x0

HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XGLOBAL_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XGLOBAL_PS_CONTEXT%\User,%DTS_EP_APO_BYPASSCNT_CAPX%,%REG_DWORD%,0x9
;; Product type DAP = 1 
HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XGLOBAL_PS_CONTEXT%\User,%DTS_APO_PRODUCT_TYPE_CAPX%,%REG_DWORD%,0x1

HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XRESERVE_PS_CONTEXT%,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,InterfaceSetting\ApoPreset1\FX\0\%DTSAPO4XRESERVE_PS_CONTEXT%\User,%PKEY_DTS_APO4X_ENTRY%,%REG_DWORD%,0x0


